      "odoo-logs": [
        {
          "type": "webview",
          "id": "odooDebugger.logPanel",
          "name": "Odoo Logs"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "odooDebugger.gotoModelFromSelection",
          "when": "resourceExtname == .py",
          "group": "odoo@1"
        },
        {
          "command": "odooDebugger.gotoXmlIdFromSelection",
          "when": "resourceExtname == .py || resourceExtname == .xml",
          "group": "odoo@2"
        },
        {
          "command": "odooDebugger.gotoFunctionDef",
          "when": "resourceExtname == .py",
          "group": "odoo@3"
        },
        {
          "command": "odooDebugger.gotoFunctionDefAll",
          "when": "resourceExtname == .py",
          "group": "odoo@4"
        },
        {
          "command": "odooDebugger.toggleModelView",
          "when": "resourceExtname == .py || resourceExtname == .xml",
          "group": "odoo@5"
        },
        {
          "command": "odooDebugger.currentModuleInfo",
          "when": "resourceExtname == .py || resourceExtname == .xml",
          "group": "odoo@6"
        }
      ],
      "view/title": [
        {
          "command": "odooDebugger.switchDatabase",
          "when": "view == odooDebugger.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "odooDebugger.manageAddonsPaths",
          "when": "view == odooDebugger.sidebar",
          "group": "navigation@2"
        },
        {
          "command": "odooDebugger.selectInterpreter",
          "when": "view == odooDebugger.sidebar",
          "group": "navigation@3"
        },
        {
          "command": "odooDebugger.openConfFile",
          "when": "view == odooDebugger.sidebar",
          "group": "navigation@4"
        },
        {
          "command": "odooDebugger.modelExplorer.filterType",
          "when": "view == odooDebugger.modelExplorer",
          "group": "navigation@1"
        },
        {
          "command": "odooDebugger.modelExplorer.moveToPanel",
          "when": "view == odooDebugger.modelExplorer",
          "group": "navigation@0"
        },
        {
          "command": "odooDebugger.modelExplorer.sortModels",
          "when": "view == odooDebugger.modelExplorer",
          "group": "navigation@2"
        },
        {
          "command": "odooDebugger.modelExplorer.toggleGroupByModule",
          "when": "view == odooDebugger.modelExplorer",
          "group": "navigation@3"
        },
        {
          "command": "odooDebugger.modelExplorer.search",
          "when": "view == odooDebugger.modelExplorer",
          "group": "navigation@4"
        },
        {
          "command": "odooDebugger.modelExplorer.clearFilter",
          "when": "view == odooDebugger.modelExplorer && odooDebuggerModelFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "odooDebugger.modelExplorer.configureSources",
          "when": "view == odooDebugger.modelExplorer",
          "group": "navigation@3"
        },
        {
          "command": "odooDebugger.refreshModelExplorer",
          "when": "view == odooDebugger.modelExplorer",
          "group": "navigation@4"
        },
        {
          "command": "odooDebugger.breakpoints.enableAll",
          "when": "view == odooDebugger.breakpoints",
          "group": "navigation@1"
        },
        {
          "command": "odooDebugger.breakpoints.disableAll",
          "when": "view == odooDebugger.breakpoints",
          "group": "navigation@2"
        },
        {
          "command": "odooDebugger.breakpoints.clearAll",
          "when": "view == odooDebugger.breakpoints",
          "group": "navigation@3"
        },
        {
          "command": "odooDebugger.sqlTools.runSql",
          "when": "view == odooDebugger.sqlTools",
          "group": "navigation@1"
        },
        {
          "command": "odooDebugger.sqlTools.filterTables",
          "when": "view == odooDebugger.sqlTools",
          "group": "navigation@1"
        },
        {
          "command": "odooDebugger.sqlTools.clearFilter",
          "when": "view == odooDebugger.sqlTools && odooDebuggerSqlFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "odooDebugger.sqlTools.refresh",
          "when": "view == odooDebugger.sqlTools",
          "group": "navigation@3"
        },
        {
          "command": "odooDebugger.sqlTools.clearHistory",
          "when": "view == odooDebugger.sqlTools",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "odooDebugger.modelExplorer.copyModelName",
          "when": "viewItem == odooModel",
          "group": "odoo@0"
        },
        {
          "command": "odooDebugger.modelExplorer.copyModelName",
          "when": "viewItem == odooModel",
          "group": "inline@0"
        },
        {
          "command": "odooDebugger.modelExplorer.gotoXmlView",
          "when": "viewItem == odooModel",
          "group": "odoo@1"
        },
        {
          "command": "odooDebugger.modelExplorer.openInBrowser",
          "when": "viewItem == odooModel",
          "group": "odoo@2"
        },
        {
          "command": "odooDebugger.modelExplorer.browseRecords",
          "when": "viewItem == odooModel",
          "group": "odoo@3"
        },
        {
          "command": "odooDebugger.modelExplorer.gotoXmlView",
          "when": "viewItem == odooModel",
          "group": "inline@1"
        },
        {
          "command": "odooDebugger.modelExplorer.openInBrowser",
          "when": "viewItem == odooModel",
          "group": "inline@2"
        },
        {
          "command": "odooDebugger.modelExplorer.browseRecords",
          "when": "viewItem == odooModel",
          "group": "inline@3"
        },
        {
          "command": "odooDebugger.modelExplorer.gotoXmlView",
          "when": "viewItem == odooModelSource",
          "group": "odoo@1"
        },
        {
          "command": "odooDebugger.modelExplorer.gotoFieldXml",
          "when": "viewItem == odooField",
          "group": "odoo@1"
        },
        {
          "command": "odooDebugger.modelExplorer.browseFieldValues",
          "when": "viewItem == odooField",
          "group": "odoo@2"
        },
        {
          "command": "odooDebugger.modelExplorer.gotoFieldXml",
          "when": "viewItem == odooField",
          "group": "inline@1"
        },
        {
          "command": "odooDebugger.modelExplorer.browseFieldValues",
          "when": "viewItem == odooField",
          "group": "inline@2"
        },
        {
          "command": "odooDebugger.modelExplorer.findMethodUsages",
          "when": "viewItem == odooMethod",
          "group": "odoo@1"
        },
        {
          "command": "odooDebugger.modelExplorer.findMethodUsages",
          "when": "viewItem == odooMethod",
          "group": "inline@1"
        },
        {
          "command": "odooDebugger.breakpoints.toggle",
          "when": "viewItem == breakpointEnabled || viewItem == breakpointDisabled",
          "group": "odoo@1"
        },
        {
          "command": "odooDebugger.breakpoints.remove",
          "when": "viewItem == breakpointEnabled || viewItem == breakpointDisabled",
          "group": "odoo@2"
        },
        {
          "command": "odooDebugger.sqlTools.browseTable",
          "when": "viewItem == sqlTable",
          "group": "odoo@1"
        },
        {
          "command": "odooDebugger.sqlTools.showColumns",
          "when": "viewItem == sqlTable",
          "group": "odoo@2"
        },
        {
          "command": "odooDebugger.sqlTools.copySelect",
          "when": "viewItem == sqlTable",
          "group": "odoo@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "odooDebugger.runOdoo",
        "key": "ctrl+shift+r",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "odooDebugger.debugOdoo",
        "key": "ctrl+shift+d",
        "when": "workspaceFolderCount > 0 && !editorTextFocus"
      },
      {
        "command": "odooDebugger.stopOdoo",
        "key": "ctrl+shift+s",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "odooDebugger.updateModule",
        "key": "ctrl+shift+u",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "odooDebugger.installModule",
        "key": "ctrl+shift+i",
        "when": "workspaceFolderCount > 0 && !editorTextFocus"
      },
      {
        "command": "odooDebugger.updateChangedModules",
        "key": "ctrl+shift+g",
        "when": "workspaceFolderCount > 0 && !editorFocus"
      },
      {
        "command": "odooDebugger.openOdoo",
        "key": "ctrl+shift+b",
        "when": "workspaceFolderCount > 0 && !editorTextFocus"
      },
      {
        "command": "odooDebugger.openShell",
        "key": "ctrl+shift+o",
        "when": "workspaceFolderCount > 0 && !editorTextFocus"
      },
      {
        "command": "odooDebugger.sqlTools.runSql",
        "key": "ctrl+shift+q",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "odooDebugger.gotoModelFromSelection",
        "key": "ctrl+shift+m",
        "when": "editorTextFocus"
      },
      {
        "command": "odooDebugger.gotoXmlIdFromSelection",
        "key": "ctrl+shift+x",
        "when": "editorTextFocus"
      },
      {
        "command": "odooDebugger.toggleModelView",
        "key": "ctrl+shift+t",
        "when": "editorTextFocus && (resourceExtname == .py || resourceExtname == .xml)"
      },
      {
        "command": "odooDebugger.gotoFunctionDef",
        "key": "ctrl+shift+.",
        "when": "editorTextFocus"
      },
      {
        "command": "odooDebugger.quickFind",
        "key": "ctrl+alt+n",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "odooDebugger.focusPanel",
        "key": "ctrl+alt+e",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "odooDebugger.modelExplorer.clearFilter",
        "key": "escape",
        "when": "view == odooDebugger.modelExplorer && odooDebuggerModelFilterActive"
      }
    ]
  },
  "scripts": {
    "lint": "eslint src/",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "eslint": "^8.50.0"
  }
}
