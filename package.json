{
  "name": "odoo-debugger",
  "displayName": "Odoo Debugger",
  "description": "All-in-one Odoo development toolkit — run, debug, update modules, navigate code, filter logs, manage breakpoints, and more. Built for Odoo developers who want to stay in VS Code.",
  "version": "1.4.0",
  "publisher": "MohitGhodasara",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MohitGhodasara/odoo-debugger"
  },
  "homepage": "https://github.com/MohitGhodasara/odoo-debugger#readme",
  "bugs": {
    "url": "https://github.com/MohitGhodasara/odoo-debugger/issues"
  },
  "keywords": [
    "odoo",
    "debugger",
    "python",
    "erp",
    "odoo18",
    "odoo17",
    "odoo16",
    "module",
    "development"
  ],
  "extensionDependencies": [
    "ms-python.debugpy"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/odoo-bin",
    "workspaceContains:**/.odoorc",
    "workspaceContains:**/odoo.conf",
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "configuration": {
      "title": "Odoo Debugger",
      "properties": {
        "odooDebugger.database": {
          "type": "string",
          "default": "",
          "description": "Default PostgreSQL database name"
        },
        "odooDebugger.venvPath": {
          "type": "string",
          "default": "",
          "description": "Path to Python virtualenv directory. Auto-detected from VS Code's selected interpreter if empty."
        },
        "odooDebugger.addonsPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom addons directory paths. Use 'Odoo: Manage Addons Paths' to configure."
        },
        "odooDebugger.configFile": {
          "type": "string",
          "default": ".odoorc",
          "description": "Odoo configuration file path (.odoorc, odoo.conf, or any Odoo conf file). Relative to workspace or absolute. DB details auto-read from it."
        },
        "odooDebugger.port": {
          "type": "number",
          "default": 8069,
          "description": "Odoo HTTP port"
        },
        "odooDebugger.upgradeScript": {
          "type": "string",
          "default": "",
          "description": "Path to custom upgrade/restart script. If empty, runs odoo-bin directly."
        },
        "odooDebugger.chromePath": {
          "type": "string",
          "default": "",
          "description": "Path to Chrome/Chromium binary for JS debugging. Auto-detected if empty."
        },
        "odooDebugger.chromeDebugPort": {
          "type": "number",
          "default": 9222,
          "description": "Chrome remote debugging port"
        },
        "odooDebugger.modelExplorer.sources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Addons directories to scan in Model Explorer. Empty = use addonsPaths."
        },
        "odooDebugger.modelExplorer.groupByModule": {
          "type": "boolean",
          "default": true,
          "description": "Group inherited model sources by module. False = flat, all fields merged."
        },
        "odooDebugger.modelExplorer.sortOrder": {
          "type": "string",
          "enum": [
            "alpha",
            "recent"
          ],
          "default": "alpha",
          "description": "Model Explorer sort order: alphabetical or recently modified."
        },
        "odooDebugger.modelExplorer.typeFilter": {
          "type": "string",
          "enum": [
            "all",
            "model",
            "transient",
            "abstract"
          ],
          "default": "model",
          "description": "Default model type filter on startup. 'model' = only models.Model (fastest). 'all' = show everything."
        },
        "odooDebugger.modelExplorer.showViews": {
          "type": "boolean",
          "default": true,
          "description": "Show a Views folder under each model in Model Explorer. Disable for zero XML scanning overhead."
        },
        "odooDebugger.odooBinPath": {
          "type": "string",
          "default": "",
          "description": "Explicit path to odoo-bin executable. Auto-detected if empty."
        },
        "odooDebugger.dbHost": {
          "type": "string",
          "default": "",
          "description": "PostgreSQL host. Empty = local socket. Auto-read from conf file if set."
        },
        "odooDebugger.dbPort": {
          "type": "string",
          "default": "",
          "description": "PostgreSQL port. Empty = 5432 default. Auto-read from conf file if set."
        },
        "odooDebugger.dbUser": {
          "type": "string",
          "default": "",
          "description": "PostgreSQL user. Empty = OS user. Auto-read from conf file if set."
        },
        "odooDebugger.dbPassword": {
          "type": "string",
          "default": "",
          "description": "PostgreSQL password. Empty = trust auth. Auto-read from conf file if set."
        },
        "odooDebugger.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional arguments passed to odoo-bin. Example: [\"--dev=all\", \"--limit-time-real=10000\", \"--max-cron-threads=0\", \"--workers=0\"]"
        },
        "odooDebugger.debugOptions": {
          "type": "object",
          "default": {
            "justMyCode": false,
            "subProcess": false
          },
          "description": "debugpy launch options. justMyCode: false = debug into library code. subProcess: false = do not attach to Odoo worker processes (faster). Add any valid debugpy launch config key here.",
          "additionalProperties": true
        },
        "odooDebugger.logPanel.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Odoo Log Panel. When enabled, --logfile is injected and logs appear in the Log Panel tab. Disable for zero overhead."
        },
        "odooDebugger.logPanel.logFile": {
          "type": "string",
          "default": "/tmp/odoo-vscode.log",
          "description": "Log file path used by the Odoo Log Panel. Truncated on every server start."
        }
      }
    },
    "commands": [
