    "viewsContainers": {
      "activitybar": [
        {
          "id": "odoo-dev",
          "title": "Odoo Debugger",
          "icon": "resources/odoo-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "odoo-logs",
          "title": "Odoo Logs",
          "icon": "resources/odoo-icon.svg"
        }
      ]
    },
    "views": {
      "odoo-dev": [
        {
          "type": "webview",
          "id": "odooDebugger.sidebar",
          "name": "Odoo Debugger"
        },
        {
          "id": "odooDebugger.modelExplorer",
          "name": "Model Explorer"
        },
        {
          "id": "odooDebugger.sqlTools",
          "name": "SQL Tools",
          "collapsed": true
        },
        {
          "type": "webview",
          "id": "odooDebugger.tools",
          "name": "Tools",
          "collapsed": true
        },
        {
          "id": "odooDebugger.breakpoints",
          "name": "Breakpoints",
          "collapsed": true
